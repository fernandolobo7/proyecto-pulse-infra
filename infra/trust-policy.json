$OIDC_ARN = (aws iam list-open-id-connect-providers --query "OpenIDConnectProviderList[0].Arn" --output text)
$OIDC_DOMAIN = $OIDC_ARN.Split('/')[-2] + "/" + $OIDC_ARN.Split('/')[-1]

$policyJson = @"
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "$OIDC_ARN"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "$($OIDC_DOMAIN):aud": "sts.amazonaws.com",
          "$($OIDC_DOMAIN):sub": "system:serviceaccount:kube-system:aws-load-balancer-controller"
        }
      }
    }
  ]
}
"@

# Usamos [System.IO.File] para evitar que PowerShell añada carácteres extraños
[System.IO.File]::WriteAllText("$(Get-Location)\trust-ultimate.json", $policyJson)